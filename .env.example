# === LLM (still NVIDIA-hosted) ===
NVIDIA_API_KEY=
NVIDIA_LLM_ENDPOINT=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct

# === TTS (local Pocket-TTS by Kyutai) ===
# 1. pipx install pocket-tts   (or: uvx pocket-tts)
# 2. pocket-tts serve --host 127.0.0.1 --port 8000
POCKETTTS_URL=http://127.0.0.1:8000

# === ASR (local Moonshine via sherpa-onnx-node) ===
# Run ./scripts/setup-models.sh once; it downloads the model tarball.
MOONSHINE_MODEL_DIR=./models/sherpa-onnx-moonshine-tiny-en-int8

# === Server ===
PORT=8080
LOG_LEVEL=info

# === Days 2+ (ignored on Day 1) ===
NASA_API_KEY=
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
ARC_RPC_URL=
X402_FACILITATOR_URL=
BUYER_WALLET_ID=
SELLER_WALLET_IDS=
