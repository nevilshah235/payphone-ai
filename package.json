{
  "name": "agentic-voice-economy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "install:all": "npm install && npm --prefix server install && npm --prefix client install",
    "postinstall": "npm --prefix server install && npm --prefix client install",
    "sanity": "npm --prefix server run sanity",
    "tts": "pocket-tts serve --host 127.0.0.1 --port 8000",
    "setup:models": "bash scripts/setup-models.sh",
    "dev": "concurrently -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
